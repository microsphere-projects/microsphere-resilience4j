    <packaging>pom</packaging>

    <name>Microsphere :: Resilience4j :: Parent</name>
    <description>Microsphere Resilience4j Parent</description>

    <properties>
        <microsphere-spring-cloud.version>0.1.10</microsphere-spring-cloud.version>
