                <spring-cloud-alibaba.version>2022.0.0.2</spring-cloud-alibaba.version>
            </properties>
        </profile>

        <profile>
            <id>spring-cloud-2023</id>
            <properties>
                <spring-boot.version>3.3.13</spring-boot.version>
                <spring-cloud.version>2023.0.6</spring-cloud.version>
                <spring-cloud-alibaba.version>2023.0.3.4</spring-cloud-alibaba.version>
            </properties>
        </profile>

        <profile>
            <id>spring-cloud-2024</id>
            <properties>
                <spring-boot.version>3.4.12</spring-boot.version>
                <spring-cloud.version>2024.0.3</spring-cloud.version>
                <spring-cloud-alibaba.version>2023.0.3.4</spring-cloud-alibaba.version>
            </properties>
        </profile>

        <profile>
            <id>spring-cloud-2025</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <spring-boot.version>3.5.8</spring-boot.version>
                <spring-cloud.version>2025.0.1</spring-cloud.version>
                <spring-cloud-alibaba.version>2025.0.0.0</spring-cloud-alibaba.version>
            </properties>
        </profile>

        <profile>
            <id>spring-cloud-2025.1</id>
            <properties>
                <spring-boot.version>4.0.0</spring-boot.version>
                <spring-cloud.version>2025.1.0</spring-cloud.version>
                <spring-cloud-alibaba.version>2025.0.0.0</spring-cloud-alibaba.version>
            </properties>
        </profile>

        <profile>
            <id>resilience4j-2.0</id>
            <properties>
                <resilience4j.version>2.0.0</resilience4j.version>
            </properties>
        </profile>

        <profile>
            <id>resilience4j-2.1</id>
            <properties>
                <resilience4j.version>2.1.0</resilience4j.version>
