            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-retrofit</artifactId>
                <version>${resilience4j.version}</version>
            </dependency>

            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-ratpack</artifactId>
                <version>${resilience4j.version}</version>
